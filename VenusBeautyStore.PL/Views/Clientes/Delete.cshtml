@model VenusBeauty.DAL.Entities.Cliente

@{
    ViewData["Title"] = "Eliminar Cliente";
}

<div class="alert alert-danger">
    ¿Estás seguro de que deseas eliminar este Cliente?
</div>

<div class="card p-3">
    <p><strong>Nombre:</strong> @Model.Nombre</p>
    <p><strong>Primer Apellido:</strong> @Model.Apellido1</p>
    <p><strong>Segundo Apellido:</strong> @Model.Apellido2</p>
    <p><strong>Correo:</strong> @Model.Correo</p>
    <p><strong>Teléfono:</strong> @Model.Telefono</p>
    <p><strong>Activo:</strong> @(Model.Activo ? "Sí" : "No")</p>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="IdCliente" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
