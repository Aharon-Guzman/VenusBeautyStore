@{
    ViewData["Title"] = "Inicio";
}

<section class="vb-hero full-bleed d-flex align-items-center">
    <div class="container-xl text-center">
        <h1>Venus Beauty Store</h1>

        <a class="btn vb-btn-dark vb-cta"
           asp-area="Identity"
           asp-page="/Account/Register">
            Crear Cuenta
        </a>
    </div>
</section>




<!-- Servicios Destacados -->
<section class="vb-section" id="servicios">
    <div class="container-xl text-center">
        <h2 class="vb-section-title mb-4">Servicios destacados</h2>

        <div class="row row-cols-1 row-cols-md-3 g-5">
            <!-- Tinte -->
            <div class="col">
                <div class="vb-feature h-100">
                    <div class="vb-feature-thumb mx-auto mb-3">
                        <img src="~/img/tinte.png" alt="Servicio de Tinte">
                    </div>
                    <h3 class="vb-feature-title">Tinte</h3>
                    <p class="vb-feature-text">
                        Transforma tu look con nuestros tintes profesionales. Contamos con una amplia
                        gama de colores vibrantes y fórmulas de alta calidad.
                    </p>
                    <a class="btn vb-btn-dark btn-sm" asp-controller="Servicios" asp-action="Index">Ver</a>
                </div>
            </div>

            <!-- Corte Dama -->
            <div class="col">
                <div class="vb-feature h-100">
                    <div class="vb-feature-thumb mx-auto mb-3">
                        <img src="~/img/corte-dama.png" alt="Servicio de Corte Dama">
                    </div>
                    <h3 class="vb-feature-title">Corte Dama</h3>
                    <p class="vb-feature-text">
                        Renueva tu imagen con cortes modernos y personalizados. Te asesoramos para
                        encontrar el corte ideal que resalte tus facciones y personalidad.
                    </p>
                    <a class="btn vb-btn-dark btn-sm" asp-controller="Servicios" asp-action="Index">Ver</a>
                </div>
            </div>

            <!-- Uñas -->
            <div class="col">
                <div class="vb-feature h-100">
                    <div class="vb-feature-thumb mx-auto mb-3">
                        <img src="~/img/unas.png" alt="Servicio de Uñas">
                    </div>
                    <h3 class="vb-feature-title">Uñas</h3>
                    <p class="vb-feature-text">
                        Luce manos impecables con manicura profesional. Diseños clásicos y vanguardistas
                        con productos de larga duración.
                    </p>
                    <a class="btn vb-btn-dark btn-sm" asp-controller="Servicios" asp-action="Index">Ver</a>
                </div>
            </div>
        </div>
    </div>
</section>






<!-- Opcional: anclas que usaremos luego para el scroll del menú -->
<section id="servicios" class="py-5"></section>
<section id="productos" class="py-5"></section>
