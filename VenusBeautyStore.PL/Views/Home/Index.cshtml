<!-- …tu hero y “Servicios destacados” estático… -->
<!-- Nuestros productos (dinámico) -->
<section class="vb-section" id="productos">
    <div class="container-xl">
        @* <h2 class="vb-section-title mb-4">Nuestros productos</h2> *@
        <h2 class="vb-section-title mb-4">
            <a asp-controller="Productos"
               asp-action="Catalogo"
               class="text-reset text-decoration-none">
                Nuestros productos
            </a>
        </h2>
        <hr class="my-4" />
        @await Html.PartialAsync("_ProductosGrid", Model.Productos)
    </div>
</section>

<!-- Nuestros servicios (dinámico) -->
<section class="vb-section" id="servicios">
    <div class="container-xl">
        @* <h2 class="vb-section-title mb-4">Nuestros servicios</h2> *@
        <h2 class="vb-section-title mb-4">
            <a asp-controller="Servicios"
               asp-action="Catalogo"
               class="text-reset text-decoration-none">
                Nuestros servicios
            </a>
        </h2>
        <hr class="my-4" />
        @await Html.PartialAsync("_ServiciosGrid", Model.Servicios)
    </div>
</section>

<section class="vb-section" id="nosotros">
    <div class="container-xl">
        <div class="vb-about-panel">
            <div class="row align-items-center g-5">
                <div class="col-12 col-lg-6">
                    <h2 class="vb-section-title mb-3">Mas Sobre Nosotros</h2>
                    <p class="vb-about-text">
                        En nuestro salón, priorizamos bienestar y excelencia, ofreciendo tratamientos de belleza
                        personalizados que combinan técnicas avanzadas con productos de alta calidad. El equipo de profesionales
                        garantiza una experiencia rejuvenecedora y revitalizante, atendiendo cada necesidad con precisión y cuidado.
                    </p>
                    <a class="btn vb-btn-dark mt-3" asp-controller="Home" asp-action="Privacy">Leer Más</a>
                    @* cambia el destino cuando tengas tu página "Nosotros" *@
                </div>

                <div class="col-12 col-lg-6">
                    <figure class="vb-about-figure mb-0">
                        <img class="vb-about-img" src="~/img/about.png" alt="Venus Beauty Salon" />
                        <figcaption class="vb-about-caption">Venus Beauty</figcaption>
                    </figure>
                </div>
            </div>
        </div>
    </div>
</section>

