@model IEnumerable<VenusBeauty.BLL.Services.UsuarioInternoDto>

<h2>Usuarios Internos</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear Usuario Interno</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>Rol</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var usuario in Model)
        {
            <tr>
                <td>@usuario.Email</td>
                <td>@usuario.Rol</td>
            </tr>
        }
    </tbody>
</table>
