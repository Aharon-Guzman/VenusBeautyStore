@model VenusBeauty.DAL.Entities.Trabajador

<h2>Editar Usuario Interno</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="IdTrabajador" />

    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Apellido" class="form-label"></label>
        <input asp-for="Apellido" class="form-control" />
        <span asp-validation-for="Apellido" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Telefono" class="form-label"></label>
        <input asp-for="Telefono" class="form-control" />
        <span asp-validation-for="Telefono" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Rol</label>
        <select asp-for="Rol" class="form-select" required>
            @if (User.IsInRole("Admin"))
            {
                <option value="Admin" selected="@(Model.Rol == "Admin")">Administrador</option>
                <option value="Recepcionista" selected="@(Model.Rol == "Recepcionista")">Recepcionista</option>
                <option value="Estilista" selected="@(Model.Rol == "Estilista")">Estilista</option>
            }
            else if (User.IsInRole("Recepcionista"))
            {
                <option value="Estilista" selected="@(Model.Rol == "Estilista")">Estilista</option>
            }
        </select>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="mb-3">
            <label class="form-label">Nueva Contraseña</label>
            <input type="password" name="NewPassword" class="form-control" />
        </div>
    }

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
