@model IEnumerable<VenusBeauty.DAL.Entities.Cita>

<h2>Listado de Citas</h2>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Cliente</th>
            <th>Trabajador</th>
            <th>Fecha</th>
            <th>Estado</th>
            <th>Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.IdCita</td>
                <td>@(c.Cliente?.Nombre) @(c.Cliente?.Apellido1) @(c.Cliente?.Apellido2)</td>
                <td>@(c.Trabajador?.Nombre) @(c.Trabajador?.Apellido)</td>
                <td>@c.FechaHora</td>
                <td>@c.Estado</td>
                <td>@c.Total.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>
<div class="mb-3">
    <a class="btn btn-primary" asp-controller="Citas" asp-action="Create">Nueva Cita</a>
</div>
