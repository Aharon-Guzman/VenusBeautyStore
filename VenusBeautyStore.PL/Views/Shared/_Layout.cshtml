<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Venus Beauty Store</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VenusBeautyStore.PL.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <header class="vb-navbar navbar navbar-expand-lg navbar-dark">
        <nav class="container-xl align-items-center">
            <a class="navbar-brand vb-brand text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">
                Venus Beauty
            </a>

            <!-- Toggler: abre el offcanvas en móvil -->
            <button class="navbar-toggler d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#vbMenu"
                    aria-controls="vbMenu" aria-label="Menú">
                <span class="navbar-toggler-icon"></span>
            </button>

            @{
                var isAuth = User?.Identity?.IsAuthenticated ?? false;
                var isAdmin = User.IsInRole("Admin");
                var isRecep = User.IsInRole("Recepcionista");
                var isEsti = User.IsInRole("Estilista");
                var isStaff = isAdmin || isRecep || isEsti;
            }

            <!-- Desktop (>= lg): menú centrado + login a la derecha -->
            <div class="collapse navbar-collapse d-none d-lg-flex w-100">
                <ul class="navbar-nav mx-auto justify-content-center align-items-lg-center gap-lg-2">
                    @* Público/cliente *@
                    @if (!isStaff)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="servicios">Servicios</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="productos">Productos</a></li>
                    }

                    @* Cliente autenticado *@
                    @if (isAuth && !isStaff)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Citas" asp-action="Index">Citas</a></li>
                    }

                    @* Reserva *@
                    @if (!isStaff)
                    {
                        if (isAuth)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Citas" asp-action="Create">Reserva</a></li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Login"
                                   asp-route-ReturnUrl="@Url.Action("Create", "Citas")">Reserva</a>
                            </li>
                        }
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">Acerca de</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Contacto</a></li>
                    }

                    @* Backoffice *@
                    @if (isAdmin || isRecep)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Productos" asp-action="Index">Productos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Servicios" asp-action="Index">Servicios</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="UsuariosInternos" asp-action="Index">Personal</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Citas" asp-action="Index">Citas</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Agenda" asp-action="Index">Agenda</a></li>
                    }
                    else if (isEsti)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Agenda" asp-action="Index">Agenda</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Citas" asp-action="Index">Citas</a></li>
                    }

                    @if (isAuth && !isStaff)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Citas" asp-action="MiCarritoActual">🛒 Mi carrito</a></li>
                    }
                </ul>

                <div class="d-flex align-items-center ms-auto">
                    @if (!isAuth)
                    {
                        <a class="btn vb-btn-dark" asp-area="Identity" asp-page="/Account/Login">Iniciar Sesión</a>
                    }
                    else
                    {

                        <partial name="_LoginPartial" />
                    }
                </div>
            </div>
        </nav>

        <!-- Móvil (< lg): offcanvas superior para que NUNCA quede detrás del contenido -->
        <div class="offcanvas offcanvas-top vb-offcanvas d-lg-none" tabindex="-1" id="vbMenu" aria-labelledby="vbMenuLabel">
            <div class="offcanvas-body">
                <ul class="navbar-nav justify-content-center align-items-center gap-2">
                    @* Público/cliente *@
                    @if (!isStaff)
                    {
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Home" asp-action="Index" asp-fragment="servicios">Servicios</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Home" asp-action="Index" asp-fragment="productos">Productos</a></li>
                    }

                    @if (isAuth && !isStaff)
                    {
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Citas" asp-action="Index">Citas</a></li>
                    }

                    @if (!isStaff)
                    {
                        if (isAuth)
                        {
                            <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Citas" asp-action="Create">Reserva</a></li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" data-bs-dismiss="offcanvas" asp-area="Identity" asp-page="/Account/Login"
                                   asp-route-ReturnUrl="@Url.Action("Create", "Citas")">Reserva</a>
                            </li>
                        }
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Home" asp-action="About">Acerca de</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Home" asp-action="Privacy">Contacto</a></li>
                    }

                    @if (isAdmin || isRecep)
                    {
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Clientes" asp-action="Index">Clientes</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Productos" asp-action="Index">Productos</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Servicios" asp-action="Index">Servicios</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="UsuariosInternos" asp-action="Index">Personal</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Citas" asp-action="Index">Citas</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Agenda" asp-action="Index">Agenda</a></li>
                    }
                    else if (isEsti)
                    {
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Agenda" asp-action="Index">Agenda</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Citas" asp-action="Index">Citas</a></li>
                    }

                    @if (isAuth && !isStaff)
                    {
                        <li class="nav-item"><a class="nav-link" data-bs-dismiss="offcanvas" asp-controller="Citas" asp-action="MiCarritoActual">🛒 Mi carrito</a></li>
                    }
                </ul>

                <div class="mt-3 text-center">
                    @if (!isAuth)
                    {
                        <a class="btn vb-btn-dark w-100" asp-area="Identity" asp-page="/Account/Login">Iniciar Sesión</a>
                    }
                    else
                    {

                        <partial name="_LoginPartial" />
                    }
                </div>
            </div>
        </div>
    </header>

    <div class="container-xl flex-grow-1">
        <main role="main" class="py-3">
            @RenderBody()
        </main>
    </div>

    <footer class="vb-footer mt-auto py-3">
        <div class="container-xl d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="vb-social d-flex gap-4 order-2 order-md-1">
                <a href="#" class="vb-social-link" aria-label="LinkedIn">
                    <svg viewBox="0 0 24 24"><path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7.5 0h3.8v2.2h.05c.53-1 1.84-2.2 3.78-2.2 4.05 0 4.8 2.67 4.8 6.15V24h-4v-7.1c0-1.7-.03-3.9-2.38-3.9-2.38 0-2.75 1.86-2.75 3.78V24h-4V8z" /></svg>
                </a>
                <a href="#" class="vb-social-link" aria-label="Instagram">
                    <svg viewBox="0 0 24 24"><path d="M12 2.2c3.2 0 3.6 0 4.9.07 1.2.06 1.9.26 2.3.43.6.23 1 .5 1.5.95.45.45.72.84.95 1.5.17.4.37 1.1.43 2.3.07 1.3.07 1.7.07 4.9s0 3.6-.07 4.9c-.06 1.2-.26 1.9-.43 2.3-.23.6-.5 1-.95 1.5-.45.45-.84.72-1.5.95-.4.17-1.1.37-2.3.43-1.3.07-1.7.07-4.9.07s-3.6 0-4.9-.07c-1.2-.06-1.9-.26-2.3-.43-.6-.23-1-.5-1.5-.95a3.8 3.8 0 0 1-.95-1.5c-.17-.4-.37-1.1-.43-2.3C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.9c.06-1.2.26-1.9.43-2.3.23-.6.5-1 .95-1.5.45-.45.84-.72 1.5-.95.4-.17 1.1-.37 2.3-.43C8.4 2.2 8.8 2.2 12 2.2z" /><path d="M12 5.8A6.2 6.2 0 1 0 18.2 12 6.2 6.2 0 0 0 12 5.8zm0 10.2A4 4 0 1 1 16 12a4 4 0 0 1-4 4z" /><circle cx="18.4" cy="5.6" r="1.3" /></svg>
                </a>
                <a href="#" class="vb-social-link" aria-label="Facebook">
                    <svg viewBox="0 0 24 24"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7h-2.7v-2.9h2.7V9.4c0-2.7 1.6-4.2 4-4.2 1.2 0 2.5.2 2.5.2v2.7h-1.4c-1.4 0-1.8.9-1.8 1.8v2.2h3l-.5 2.9h-2.5v7A10 10 0 0 0 22 12z" /></svg>
                </a>
            </div>

            <ul class="vb-footer-links d-flex flex-wrap gap-3 gap-md-5 mb-0 order-1 order-md-2">
                <li><a href="#">Dirección</a></li>
                <li><a href="#">Ayuda</a></li>
                <li><a asp-controller="Home" asp-action="Privacy">Contacto</a></li>
            </ul>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
