@using VenusBeauty.DAL.Entities
@model IEnumerable<Servicio>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-light border text-center">Aún no hay servicios para mostrar.</div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
        @foreach (var s in Model)
        {
            var img = string.IsNullOrWhiteSpace(s.ImagenUrl)
            ? Url.Content("~/img/placeholder-service.jpg")
            : s.ImagenUrl;

            <div class="col">
                <div class="card vb-product-card h-100">
                    <div class="vb-card-img-wrap">
                        <img class="vb-card-img" src="@img" alt="@s.Nombre" />
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h3 class="vb-product-title">@s.Nombre</h3>

                        @* opcional *@
                        @if (!string.IsNullOrWhiteSpace(s.Descripcion))
                        {
                            <p class="vb-product-desc">@s.Descripcion</p>
                        }

                        <div class="mt-auto d-flex align-items-center justify-content-between">
                            @* si tienes precio/duración, muéstralos *@
                            @* <span class="vb-price">@s.Precio.ToString("C")</span> *@
                            <a class="btn btn-sm vb-btn-dark" asp-controller="Home" asp-action="Servicios">
                                Ver
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
