@model IEnumerable<VenusBeauty.DAL.Entities.Servicio>

<h2>Lista de Servicios</h2>

<form id="antiForgeryForm" method="post">
    @Html.AntiForgeryToken()
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Duración (min)</th>
            <th>Precio</th>
            <th>Activo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var servicio in Model)
        {
            <tr>
                <td>@servicio.Nombre</td>
                <td>@servicio.Descripcion</td>
                <td>@servicio.Duracion</td>
                <td>@servicio.Precio.ToString("C")</td>
                <td>
                    <div class="form-check form-switch">
                        <input type="checkbox" class="form-check-input toggle-activo-servicio"
                               data-id="@servicio.IdServicio"
                               @(servicio.Activo ? "checked" : "") />
                    </div>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@servicio.IdServicio" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Delete" asp-route-id="@servicio.IdServicio" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mb-3">
    <a class="btn btn-primary" asp-controller="Servicios" asp-action="Create">Nuevo Servicio</a>
</div>

@section Scripts {
    <script src="~/js/servicios/servicios.js"></script>
}
