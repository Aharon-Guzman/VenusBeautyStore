@model IEnumerable<VenusBeauty.DAL.Entities.Servicio>
@{
    ViewData["Title"] = "Servicios";
    var q = ViewBag.Q as string;
    int? targetId = ViewBag.TargetServicioId as int?;
}

<h1 class="mb-3">Servicios</h1>

@if (!string.IsNullOrWhiteSpace(q))
{
    <div class="alert alert-info d-flex justify-content-between align-items-center">
        <span>Filtrado por: <strong>@q</strong></span>
        <a class="btn btn-sm btn-outline-secondary" asp-action="Catalogo">Limpiar filtro</a>
    </div>
}

<style>
    .vb-highlight {
        outline: 3px solid;
        outline-offset: 2px;
        border-radius: 10px;
    }
</style>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var s in Model)
    {
        <div class="col" id="svc-@s.IdServicio">
            <div class="card h-100 shadow-sm">
                <img src="@s.ImagenUrl" class="card-img-top" alt="@s.Nombre" />
                <div class="card-body">
                    <h5 class="card-title">@s.Nombre</h5>
                    <p class="card-text">Duración: @s.Duracion min</p>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <span class="fw-bold">@s.Precio.ToString("C")</span>
                    <a class="btn btn-primary"
                       asp-controller="Citas"
                       asp-action="ReservarServicio"
                       asp-route-idServicio="@s.IdServicio">
                        Reservar
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        (function() {
          let anchor = window.location.hash?.replace('#', '');
          if (!anchor && '@(targetId?.ToString() ?? "")' !== '') {
              anchor = 'svc-' + '@targetId';
          }
          if (!anchor) return;

          const el = document.getElementById(anchor);
          if (!el) return;

          el.scrollIntoView({ behavior: 'smooth', block: 'center' });
          el.classList.add('vb-highlight');
          setTimeout(() => el.classList.remove('vb-highlight'), 2000);
        })();
    </script>
}
